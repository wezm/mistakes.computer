(def allkeys (keys mistakes))

(defn mistake-text [slug]
  (let [mistake (get mistakes slug '("Breaking URLs" :was))]
    (string/join (tuple/join mistake '("a mistake")) " ")))

(defn pick [] (randgen/rand-value allkeys))

