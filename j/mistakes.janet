    "excel" '("Excel" :was)
    "facebook" '("Facebook" :was)
    "gc" '("Garbage collection" :was)
    "github" '("GitHub" :was)
    "gtlds" '("gTLDs" :were)
    "hacker-news" '("Hacker News" :was)
